// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id          Int      @id @default(autoincrement())
  merchant    String?
  total       Float?
  category    String?
  receiptDate DateTime?
  imagePath   String
  rawText     String?
  createdAt   DateTime @default(now())
}